# 本地开发环境（可选，默认就是 localhost:18795）
# VITE_GATEWAY_URL=http://localhost:18795

# 生产环境 - 替换为您的公网地址
# 方案 1: 使用内网穿透工具（推荐用于测试）
#   - ngrok: ngrok http 18795 → https://xxx.ngrok.io
#   - Cloudflare Tunnel: https://xxx.trycloudflare.com
# VITE_GATEWAY_URL=https://your-tunnel-address.ngrok.io

# 方案 2: 后端部署到云服务器
# VITE_GATEWAY_URL=https://your-server.com

# 方案 3: 后端也部署到 Vercel/其他云平台
# VITE_GATEWAY_URL=https://your-api.vercel.app
