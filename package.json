{
  "name": "voice-gateway",
  "version": "1.0.0",
  "description": "OpenClaw 语音通话网关插件",
  "main": "dist/index.js",
  "openclaw": {
    "extensions": [
      "dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "clean": "rm -rf dist",

    "test:p0": "ts-node --transpile-only scripts/verify_p0_regression.ts",

    "test:router": "ts-node --transpile-only scripts/validation/router/accuracy.ts",
    "test:router:integrated": "ts-node --transpile-only scripts/validation/router/integrated-accuracy.ts",
    "test:router:model": "ts-node --transpile-only scripts/validation/router/accuracy.ts",
    "test:router:latency": "ts-node --transpile-only scripts/validation/router/latency.ts",

    "test:slc": "ts-node --transpile-only scripts/validation/slc/ttft.ts",
    "test:sle": "ts-node --transpile-only scripts/validation/sle/tool-execution.ts",

    "test:all": "ts-node --transpile-only scripts/validation/index.ts --all",
    "test:report": "ts-node --transpile-only scripts/validation/index.ts --report",
    "test:validate": "ts-node --transpile-only scripts/validation/index.ts",
    "test:zego-assistant": "ts-node --transpile-only scripts/verify-zego-ai-assistant.ts"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.32.35",
    "@types/js-yaml": "^4.0.9",
    "@types/proper-lockfile": "^4.1.4",
    "axios": "^1.13.6",
    "js-yaml": "^4.1.1",
    "openai": "^6.25.0",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.20",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
